FROM python:3.13-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY agents/ agents/
COPY contracts/ contracts/
COPY client_app.py .
COPY client_service.py .

EXPOSE 8001
ENTRYPOINT ["python3", "client_service.py"]
CMD ["--host", "0.0.0.0", "--port", "8001"]
